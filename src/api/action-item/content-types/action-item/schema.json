{
  "kind": "collectionType",
  "collectionName": "action_items",
  "info": {
    "singularName": "action-item",
    "pluralName": "action-items",
    "displayName": "Action Item",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "dueDate": {
      "type": "date"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "Pending",
        "In Progress",
        "Completed"
      ],
      "default": "Pending"
    },
    "priority": {
      "type": "enumeration",
      "enum": [
        "High",
        "Medium",
        "Low"
      ]
    }
  }
}
